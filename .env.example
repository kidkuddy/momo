# Homeserver base URL.
HOMESERVER=https://matrix.org

# The bot's own Matrix account. BOT_USER is the localpart.
# Both are only needed for the first login — after that the saved token is used.
# Keep BOT_PASSWORD anyway: rebuilding after a lost momo.db needs it.
BOT_USER=yourbot
BOT_PASSWORD=

# The ONLY user momo obeys, as a full user ID.
# This is the entire security model. With ENGINE=claude, whoever holds this
# account runs Claude Code on this machine as you.
ALLOWED_USER=@you:matrix.org

# Uncomment to actually run Claude Code. Anything else means the echo engine,
# which is the default so a stray run cannot execute anything.
# ENGINE=claude

# Working directory for the engine. Defaults to $HOME.
# WORKDIR=/path/to/project

# Verbose mautrix logging — the only way to see key sharing and decryption problems.
# DEBUG=1
