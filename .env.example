# Homeserver base URL.
HOMESERVER=https://matrix.org

# The bot's own Matrix account. BOT_USER is the localpart.
# Both are only needed for the first login — after that the saved token is used.
# Keep BOT_PASSWORD anyway: rebuilding after a lost momo.db needs it.
BOT_USER=yourbot
BOT_PASSWORD=

# The ONLY user momo obeys, as a full user ID.
# This is the entire security model. With ENGINE=claude, whoever holds this
# account runs Claude Code on this machine as you.
ALLOWED_USER=@you:matrix.org

# Uncomment to actually run Claude Code. Anything else means the echo engine,
# which is the default so a stray run cannot execute anything.
# ENGINE=claude

# Working directory for the engine. Defaults to $HOME.
# WORKDIR=/path/to/project

# Path to the agent binary. Set this for a long-running daemon: a PATH inherited
# from an interactive shell can point at a per-session shim that later disappears.
# CLAUDE_BIN=/Users/you/.local/bin/claude

# How long one agent session may run before it is killed.
# ENGINE_TIMEOUT=10m

# What the agent may do without asking. A headless session has nobody to ask, so
# anything other than bypassPermissions makes it refuse actions and never reply.
# Default: bypassPermissions.
# ENGINE_PERMISSION_MODE=bypassPermissions

# Narrower posture: restrict the session to specific tools. Enough to reply and
# read, without letting it write:
# ENGINE_ALLOWED_TOOLS=Bash(momo:*) Read Grep Glob

# Verbose mautrix logging — the only way to see key sharing and decryption problems.
# DEBUG=1
